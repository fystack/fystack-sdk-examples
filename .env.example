# Fystack API Credentials
FYSTACK_API_KEY=your_api_key_here
FYSTACK_API_SECRET=your_api_secret_here

# Workspace ID (required for some operations)
FYSTACK_WORKSPACE_ID=your_workspace_id_here

FYSTACK_ENVIRONMENT=production

# Wallet ID (for operations that require an existing wallet)
WALLET_ID=your_wallet_id_here

# Asset ID (for withdrawal operations)
ASSET_ID=your_asset_id_here

# RPC Endpoints
ETHEREUM_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# Test recipient addresses
ETH_RECIPIENT_ADDRESS=0x0000000000000000000000000000000000000000
SOLANA_RECIPIENT_ADDRESS=11111111111111111111111111111111
