{
  "name": "fystack-sdk-examples",
  "version": "1.0.0",
  "description": "Example project demonstrating Fystack Wallet SDK usage",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "create-wallet": "ts-node src/examples/create-wallet.ts",
    "get-deposit-address": "ts-node src/examples/get-deposit-address.ts",
    "create-withdrawal": "ts-node src/examples/create-withdrawal.ts",
    "eth-transfer": "ts-node src/examples/eth-transfer.ts",
    "solana-transfer": "ts-node src/examples/solana-transfer.ts",
